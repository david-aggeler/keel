{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/david-aggeler/keel/vscode/schemas/setup-plan.json",
  "title": "consumer VS Code selected-test setup plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "devtool",
    "workspace",
    "generated_at",
    "groups"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 3
    },
    "devtool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "commit", "built_at"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string"
        },
        "built_at": {
          "type": "string"
        }
      }
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "teardown_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "order", "mutually_exclusive", "rows"],
      "allOf": [
        {
          "if": {
            "properties": {
              "mutually_exclusive": {
                "const": true
              }
            },
            "required": ["mutually_exclusive"]
          },
          "then": {
            "properties": {
              "rows": {
                "contains": {
                  "type": "object",
                  "required": ["active"],
                  "properties": {
                    "active": {
                      "const": true
                    }
                  }
                },
                "minContains": 1,
                "maxContains": 1
              }
            }
          }
        }
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer"
        },
        "mutually_exclusive": {
          "type": "boolean"
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/desired_state"
          }
        }
      }
    },
    "desired_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource", "kind", "desired", "current", "status", "action", "message", "reusable", "owned"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["tool", "dependency", "binary", "host-port-set", "fixture-data", "credential", "service", "unknown"]
        },
        "desired": {
          "type": "string",
          "minLength": 1
        },
        "current": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["satisfied", "blocked", "reconcilable"]
        },
        "action": {
          "type": "string",
          "enum": ["reuse", "manual_setup_required", "reconcile", "reconcile_during_run"]
        },
        "message": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "reusable": {
          "type": "boolean"
        },
        "owned": {
          "type": "boolean"
        },
        "active": {
          "type": "boolean"
        }
      }
    }
  }
}
