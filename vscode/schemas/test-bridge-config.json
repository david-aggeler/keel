{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/david-aggeler/keel/vscode/schemas/test-bridge-config.schema.json",
  "title": "Keel Test Bridge Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "command", "args", "displayName"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
